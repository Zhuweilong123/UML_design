# ── DeepSeek LLM ────────────────────────────────────
# Replace with your own DeepSeek API key
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Internal API Auth ───────────────────────────────
# Set this to a secret token to protect LLM/pipeline/file-write endpoints.
# Frontend must set VITE_API_TOKEN to the same value in frontend/.env.local
# Leave empty during local dev to skip auth entirely.
INTERNAL_API_TOKEN=
