        },
        {
          "id": "msg_1782307969791_k9dc5l",
          "from_lifeline": "life_1782307952870_4r4djd",
          "to_lifeline": "life_1782307952870_4r4djd",
          "label": "message()",
          "type": "sync",
          "order": 2,
          "y": 250.0,
          "note": "处理ota场景：1、如果鸡叫时间可能在ota升级期间，取消鸡叫任务，防止鸡叫打断ota升级；2、如果鸡叫在ota之后，取消鸡叫任务，因为ota结束之后会自动重启系统。"
        },
        {
          "id": "msg_1782307975259_z96443",
          "from_lifeline": "life_1782307952870_4r4djd",
          "to_lifeline": "life_1782307951406_o0vl10",
          "label": "message()",
          "type": "return",
          "order": 3,
          "y": 330.0,
          "note": "将鸡叫进程对ota的处理返回给ota进程"
        },
        {
          "id": "msg_1782307980289_8r7qw1",
          "from_lifeline": "life_1782307951406_o0vl10",
          "to_lifeline": "life_1782307951406_o0vl10",
